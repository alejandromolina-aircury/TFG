generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Staff {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         StaffRole @default(STAFF)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

model Customer {
  id              String         @id @default(uuid())
  email           String         @unique
  phone           String
  firstName       String
  lastName        String
  language        Language       @default(ES)
  allergens       String[]
  preferences     String?
  birthday        DateTime?
  totalVisits     Int            @default(0)
  isVip           Boolean        @default(false)
  isBlacklisted   Boolean        @default(false)
  previousEmails  String[]       @default([])
  previousPhones  String[]       @default([])
  previousNames   String[]       @default([])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  blacklistReason String?
  tags            String[]
  totalNoShows    Int            @default(0)
  bookings        Booking[]
  notes           CustomerNote[]
  waitlist        Waitlist[]

  @@index([email])
  @@index([phone])
}

model CustomerNote {
  id         String   @id @default(uuid())
  note       String
  createdBy  String
  customerId String
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Zone {
  id           Int      @id @default(autoincrement())
  name         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  description  String?
  displayOrder Int      @default(0)
  updatedAt    DateTime @updatedAt
  tables       Table[]
}

model Table {
  id          Int       @id @default(autoincrement())
  name        String
  minCapacity Int
  maxCapacity Int
  zoneId      Int
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
  zone        Zone      @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([zoneId])
  @@index([isActive])
}

model Booking {
  id                String        @id @default(uuid())
  date              DateTime
  duration          Int           @default(120)
  pax               Int
  status            BookingStatus @default(PENDING)
  specialRequests   String?
  customerId        String
  tableId           Int?
  confirmationToken String?       @unique
  reconfirmToken    String?       @unique
  emailSentAt       DateTime?
  reconfirmedAt     DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  assignedBy        String?
  completedAt       DateTime?
  confirmedAt       DateTime?
  modifiedAt        DateTime?
  seatedAt          DateTime?
  source            BookingSource @default(WEB)
  customer          Customer      @relation(fields: [customerId], references: [id])
  table             Table?        @relation(fields: [tableId], references: [id])

  @@index([date, status])
  @@index([customerId])
  @@index([tableId])
  @@index([confirmationToken])
}

model Shift {
  id                 Int       @id @default(autoincrement())
  name               String
  startTime          String
  endTime            String
  isActive           Boolean   @default(true)
  daysOfWeek         Int[]
  slotInterval       Int       @default(30)
  maxBookingsPerSlot Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  closures           Closure[]
}

model Closure {
  id        String    @id @default(uuid())
  startDate DateTime
  endDate   DateTime?
  reason    String
  isFullDay Boolean   @default(true)
  shiftId   Int?
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  shift     Shift?    @relation(fields: [shiftId], references: [id])

  @@index([startDate, endDate])
}

model Waitlist {
  id         String    @id @default(uuid())
  date       DateTime
  pax        Int
  notes      String?
  isResolved Boolean   @default(false)
  customerId String
  createdAt  DateTime  @default(now())
  notifiedAt DateTime?
  resolvedAt DateTime?
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([date, isResolved])
  @@index([customerId])
}

model SystemConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model MenuCategory {
  id           Int        @id @default(autoincrement())
  name         String
  description  String?
  isActive     Boolean    @default(true)
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  items        MenuItem[]

  @@index([isActive])
}

model MenuItem {
  id           Int          @id @default(autoincrement())
  name         String
  description  String?
  price        String
  isActive     Boolean      @default(true)
  displayOrder Int          @default(0)
  categoryId   Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  category     MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([isActive])
}

enum StaffRole {
  ADMIN
  STAFF
}

enum Language {
  ES
  EN
  FR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  RECONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  WEB
  PHONE
  WALK_IN
  BACKOFFICE
}
