// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum StaffRole {
  ADMIN
  STAFF
}

enum Language {
  ES
  EN
  FR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  RECONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  WEB          // Reserva online del cliente
  PHONE        // Llamada telefónica
  WALK_IN      // Pasante (sin reserva previa)
  BACKOFFICE   // Creada desde panel de gestión
}

// --- MODELOS ---

// 🔐 PERSONAL DEL RESTAURANTE (Login)
model Staff {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         StaffRole @default(STAFF)
  isActive     Boolean   @default(true)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

// 👤 CRM DE CLIENTES
model Customer {
  id            String    @id @default(uuid())
  email         String    @unique
  phone         String
  firstName     String
  lastName      String
  language      Language  @default(ES)
  
  // Datos CRM
  allergens     String[]  // Array nativo de Postgres: ["Gluten", "Lactosa"]
  tags          String[]  // ["VIP", "Cumpleaños"]
  preferences   String?   // Notas generales

  birthday      DateTime?
  
  // Métricas
  totalVisits   Int       @default(0)
  totalNoShows  Int       @default(0)
  isVip         Boolean   @default(false)
  isBlacklisted Boolean   @default(false)
  blacklistReason String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relaciones
  bookings      Booking[]
  waitlist      Waitlist[]
  notes         CustomerNote[]

  @@index([email])
  @@index([phone])
}

// 📝 Notas del Staff sobre Clientes
model CustomerNote {
  id          String   @id @default(uuid())
  note        String
  createdBy   String   // Nombre del staff
  
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@index([customerId])
}

// 🏢 GESTIÓN DE ESPACIO

model Zone {
  id          Int       @id @default(autoincrement())
  name        String    // "Salón Principal"
  description String?
  isActive    Boolean   @default(true)
  displayOrder Int      @default(0)
  
  tables      Table[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Table {
  id              Int      @id @default(autoincrement())
  name            String   // "Mesa 1", "Mesa A-2"
  minCapacity     Int
  maxCapacity     Int
  isActive        Boolean  @default(true)
  
  zoneId          Int
  zone            Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  
  bookings        Booking[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([zoneId])
  @@index([isActive])
}

// 🎫 MOTOR DE RESERVAS

model Booking {
  id              String        @id @default(uuid())
  date            DateTime      // Fecha y hora de inicio
  duration        Int           @default(120) // Minutos
  pax             Int
  status          BookingStatus @default(PENDING)
  source          BookingSource @default(WEB)
  specialRequests String?
  
  // Gestión
  assignedBy      String?
  modifiedAt      DateTime?
  confirmedAt     DateTime?
  seatedAt        DateTime?
  completedAt     DateTime?
  
  // Relaciones
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id])
  
  tableId         Int?
  table           Table?        @relation(fields: [tableId], references: [id])

  // Tokens de gestión por email
  confirmationToken String?     @unique
  reconfirmToken    String?     @unique
  emailSentAt       DateTime?
  reconfirmedAt     DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([date, status])
  @@index([customerId])
  @@index([tableId])
  @@index([confirmationToken])
}

// 📅 CONFIGURACIÓN DE TURNOS

model Shift {
  id          Int      @id @default(autoincrement())
  name        String   // "Comidas"
  startTime   String   // "13:30" (formato HH:mm)
  endTime     String   // "17:00"
  isActive    Boolean  @default(true)
  daysOfWeek  Int[]    // [2,3,4,5,6] donde 0=Domingo, 1=Lunes... 6=Sábado
  
  slotInterval Int     @default(30) // Intervalo entre horas disponibles (minutos)
  maxBookingsPerSlot Int?
  
  closures    Closure[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 🚫 CIERRES Y BLOQUEOS

model Closure {
  id          String    @id @default(uuid())
  startDate   DateTime
  endDate     DateTime?
  reason      String
  isFullDay   Boolean   @default(true)
  
  shiftId     Int?
  shift       Shift?    @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([startDate, endDate])
}

// ⏳ LISTA DE ESPERA

model Waitlist {
  id          String   @id @default(uuid())
  date        DateTime
  pax         Int
  notes       String?
  isResolved  Boolean  @default(false)
  resolvedAt  DateTime?
  notifiedAt  DateTime?
  
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@index([date, isResolved])
  @@index([customerId])
}

// 🔧 CONFIGURACIÓN DEL SISTEMA

model SystemConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}
