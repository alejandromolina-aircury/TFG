{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Customer List API",
  "description": "Contract for GET /api/customers - Returns paginated list of customers with search and filters",
  "type": "object",
  "properties": {
    "query": {
      "type": "object",
      "properties": {
        "search": { "type": "string", "description": "Search term for name, email, phone" },
        "isVip": { "type": "boolean", "description": "Filter by VIP status" },
        "isBlacklisted": { "type": "boolean", "description": "Filter by blacklist status" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Filter by tags" },
        "page": { "type": "integer", "minimum": 1, "default": 1 },
        "limit": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
      }
    },
    "response": {
      "type": "object",
      "properties": {
        "customers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "email": { "type": "string", "format": "email" },
              "phone": { "type": "string" },
              "firstName": { "type": "string" },
              "lastName": { "type": "string" },
              "language": { "enum": ["ES", "EN", "FR"] },
              "tags": { "type": "array", "items": { "type": "string" } },
              "isVip": { "type": "boolean" },
              "isBlacklisted": { "type": "boolean" },
              "totalVisits": { "type": "integer", "minimum": 0 },
              "totalNoShows": { "type": "integer", "minimum": 0 },
              "createdAt": { "type": "string", "format": "date-time" },
              "updatedAt": { "type": "string", "format": "date-time" }
            },
            "required": ["id", "email", "firstName", "lastName", "language", "tags", "isVip", "isBlacklisted", "totalVisits", "totalNoShows", "createdAt", "updatedAt"]
          }
        },
        "total": { "type": "integer", "minimum": 0 },
        "page": { "type": "integer", "minimum": 1 },
        "limit": { "type": "integer", "minimum": 1 }
      },
      "required": ["customers", "total", "page", "limit"]
    }
  }
}