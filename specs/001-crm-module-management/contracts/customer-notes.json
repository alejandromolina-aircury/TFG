{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Customer Notes API",
  "description": "Contract for POST /api/customers/:id/notes - Adds a new note to customer",
  "type": "object",
  "properties": {
    "params": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid", "description": "Customer UUID" }
      },
      "required": ["id"]
    },
    "request": {
      "type": "object",
      "properties": {
        "note": { "type": "string", "minLength": 1, "description": "Note content" }
      },
      "required": ["note"]
    },
    "response": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean", "const": true },
        "note": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "format": "uuid" },
            "note": { "type": "string" },
            "createdBy": { "type": "string" },
            "createdAt": { "type": "string", "format": "date-time" }
          },
          "required": ["id", "note", "createdBy", "createdAt"]
        }
      },
      "required": ["success", "note"]
    }
  }
}