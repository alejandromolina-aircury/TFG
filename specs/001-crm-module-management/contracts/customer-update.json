{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Customer Update API",
  "description": "Contract for PATCH /api/customers/:id - Updates customer fields",
  "type": "object",
  "properties": {
    "params": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid", "description": "Customer UUID" }
      },
      "required": ["id"]
    },
    "request": {
      "type": "object",
      "properties": {
        "phone": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "language": { "enum": ["ES", "EN", "FR"] },
        "allergens": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "preferences": { "type": "string" },
        "birthday": { "type": "string", "format": "date" },
        "isVip": { "type": "boolean" },
        "isBlacklisted": { "type": "boolean" },
        "blacklistReason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean", "const": true },
        "customer": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "format": "uuid" },
            "email": { "type": "string", "format": "email" },
            "phone": { "type": "string" },
            "firstName": { "type": "string" },
            "lastName": { "type": "string" },
            "language": { "enum": ["ES", "EN", "FR"] },
            "allergens": { "type": "array", "items": { "type": "string" } },
            "tags": { "type": "array", "items": { "type": "string" } },
            "preferences": { "type": "string" },
            "birthday": { "type": "string", "format": "date" },
            "totalVisits": { "type": "integer", "minimum": 0 },
            "totalNoShows": { "type": "integer", "minimum": 0 },
            "isVip": { "type": "boolean" },
            "isBlacklisted": { "type": "boolean" },
            "blacklistReason": { "type": "string" },
            "createdAt": { "type": "string", "format": "date-time" },
            "updatedAt": { "type": "string", "format": "date-time" }
          },
          "required": ["id", "email", "firstName", "lastName", "language", "allergens", "tags", "isVip", "isBlacklisted", "totalVisits", "totalNoShows", "createdAt", "updatedAt"]
        }
      },
      "required": ["success", "customer"]
    }
  }
}