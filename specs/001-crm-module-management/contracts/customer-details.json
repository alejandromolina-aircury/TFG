{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Customer Details API",
  "description": "Contract for GET /api/customers/:id - Returns full customer details with notes and booking history",
  "type": "object",
  "properties": {
    "params": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid", "description": "Customer UUID" }
      },
      "required": ["id"]
    },
    "response": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "language": { "enum": ["ES", "EN", "FR"] },
        "allergens": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "preferences": { "type": "string" },
        "birthday": { "type": "string", "format": "date" },
        "totalVisits": { "type": "integer", "minimum": 0 },
        "totalNoShows": { "type": "integer", "minimum": 0 },
        "isVip": { "type": "boolean" },
        "isBlacklisted": { "type": "boolean" },
        "blacklistReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "notes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "note": { "type": "string" },
              "createdBy": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" }
            },
            "required": ["id", "note", "createdBy", "createdAt"]
          }
        },
        "recentBookings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "date": { "type": "string", "format": "date" },
              "time": { "type": "string" },
              "partySize": { "type": "integer", "minimum": 1 },
              "status": { "enum": ["PENDING", "CONFIRMED", "COMPLETED", "CANCELLED", "NO_SHOW"] },
              "createdAt": { "type": "string", "format": "date-time" }
            },
            "required": ["id", "date", "time", "partySize", "status", "createdAt"]
          }
        }
      },
      "required": ["id", "email", "firstName", "lastName", "language", "allergens", "tags", "isVip", "isBlacklisted", "totalVisits", "totalNoShows", "createdAt", "updatedAt", "notes", "recentBookings"]
    }
  }
}