{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "New Reservation Socket Event",
  "description": "Contract for the backoffice Socket.io event emitted when a new reservation is created.",
  "type": "object",
  "properties": {
    "event": {
      "type": "string",
      "const": "new_reservation"
    },
    "payload": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "pax": { "type": "integer", "minimum": 1 },
        "status": { "type": "string" },
        "tableName": { "type": ["string", "null"] },
        "zoneName": { "type": ["string", "null"] },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" }
      },
      "required": ["id", "date", "pax", "status", "customerName", "customerEmail"]
    }
  },
  "required": ["event", "payload"]
}
